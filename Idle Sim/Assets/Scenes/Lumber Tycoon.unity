  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<align=center><size=120%><color=#A52A2A>THE FINAL FRONTIER</color></size></align>\n\n<align=left><b><color=#D2691E>\U0001F341
    The Maple Forest:</color></b>\nYou've reached the heart of the forest! These
    <b>Maple Trees</b> are sturdy\u2014it will take more strength to bring them down,
    but the rewards are far greater.\n\n<b><color=#8B4513>\U0001F3E1 The Master Architect:</color></b>\nThis
    is the ultimate test of a true woodsman. Only those who can master this land
    may build the <b>Legendary Estate</b>.\n\n<b><color=#32CD32>Final Goal:</color></b>
    Collect <b>5,000 Maple</b> to construct your <color=#FFD700>Grand House</color>
    and complete your legacy!</align>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
